{
  "name": "truth-of-fun-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace @truth-of-fun/web",
    "web:build": "npm run build --workspace @truth-of-fun/web",
    "web:lint": "npm run lint --workspace @truth-of-fun/web",
    "web:typecheck": "npm run typecheck --workspace @truth-of-fun/web",
    "web:test": "npm run test --workspace @truth-of-fun/web",
    "web:test:e2e": "npm run test:e2e --workspace @truth-of-fun/web",
    "api-client:build": "npm run build --workspace @truth-of-fun/api-client",
    "mobile:info": "npm run info --workspace @truth-of-fun/mobile"
  },
  "overrides": {
    "next@15.5.15": {
      "postcss": "8.5.14"
    }
  }
}
