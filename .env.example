APP_NAME=truth-of-fun
APP_ENV=development
CORS_ALLOWED_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5433/truth_of_fun

# REQUIRED for production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Provider API keys (leave blank to disable that source)
TICKETMASTER_API_KEY=
MEETUP_API_TOKEN=
ANTHROPIC_API_KEY=

# Reddit OAuth — create a "script" app at https://www.reddit.com/prefs/apps
# (anonymous Reddit JSON access is blocked; live ingestion requires this).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=truth-of-fun/0.1 (event discovery; +https://github.com/MatthewARoy/truth-of-fun)

# Optional tunables (defaults shown)
# WORKER_INTERVAL_SECONDS=21600
# JWT_EXPIRE_MINUTES=10080

# AAIM (internal auth & secrets store) - keep disabled for local/OSS use
AAIM_ENABLED=false
AAIM_FALLBACK_TO_ENV=true
AAIM_OIDC_ISSUER=
AAIM_OIDC_AUDIENCE=
AAIM_OIDC_JWKS_URL=
AAIM_JWT_SHARED_SECRET=
AAIM_JWT_ALGORITHMS=["RS256","HS256"]
REDIS_URL=redis://127.0.0.1:6379/0
AAIM_REDIS_PREFIX=aaim
AAIM_TICKETMASTER_QUOTA_LIMIT=10000
# Hours before an exhausted key auto-reactivates (quota window rollover); 0 disables.
AAIM_QUOTA_WINDOW_HOURS=24

# Optional: webhook URL for operational alerts (Slack/Discord)
ALERT_WEBHOOK_URL=

# Optional: IMAP mailbox for newsletter ingestion (Eddie's List).
# Leave blank to disable the eddies_list source.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
EDDIES_LIST_ALLOWED_SENDERS=["eddieslist.com"]

# Optional: proxy for scrapers (single URL or rotation list as JSON array)
# PROXY_URL=http://user:pass@proxy.example.com:8080
# PROXY_ROTATION=["http://proxy1:8080","http://proxy2:8080"]
