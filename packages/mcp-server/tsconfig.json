{
  "compilerOptions": {
    "target": "ES2022",
    // NodeNext (not Bundler) because this runs directly under node as a stdio
    // process, with no bundler to resolve specifiers for it.
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["src"]
}
