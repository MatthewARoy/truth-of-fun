{
  "name": "@truth-of-fun/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server exposing Truth of Fun event discovery to Claude and other MCP clients.",
  "main": "dist/index.js",
  "bin": {
    "truth-of-fun-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
